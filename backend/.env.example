SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOW_ALL_ORIGINS=True

# Local SQLite (recommended for dev). With USE_SQLITE=True the DB_* values
# below are ignored.
USE_SQLITE=True
SQLITE_NAME=backend.sqlite3

# PostgreSQL (production / Choreo). Used when USE_SQLITE is not True and
# DB_NAME is set.
DB_ENGINE=django.db.backends.postgresql
DB_NAME=
DB_USER=
DB_PWD=
DB_HOST=
DB_PORT=5432
